{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "envai-site",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8765"],
      "port": 8765
    },
    {
      "name": "envai-platform-app",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "envai-platform/app", "run", "dev"],
      "port": 5173
    },
    {
      "name": "envai-platform-dist",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4173", "--directory", "envai-platform/app/dist"],
      "port": 4173
    }
  ]
}
